   "id": "68126f00",
   "metadata": {},
   "outputs": [],
   "source": [
    "modelo = LinearRegression()\n",
    "modelo.fit(x, y)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c598f9a1",
   "metadata": {},
   "outputs": [],
   "source": [
