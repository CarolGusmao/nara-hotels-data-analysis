   "id": "d6d028f8",
   "metadata": {},
   "outputs": [],
   "source": [
    "df_reservas_validas = df_reservas[df_reservas['status_reserva'].isin(['Confirmada','Concluída'])]\n",
    "df_reservas_validas.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "bfbbd210",
   "metadata": {},
   "source": [
    "#Período das reservas"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "74e9bc51",
   "metadata": {},
   "outputs": [],
   "source": [
    "data_inicio_reserva = pd.to_datetime(df_reservas_validas['data_checkin']).min()\n",
    "data_fim_reserva = pd.to_datetime(df_reservas_validas['data_checkout']).max()\n",
    "periodo = (data_fim_reserva - data_inicio_reserva).days\n",
    "print(\"Data início:\", data_inicio_reserva)\n",
    "print(\"Data fim:\", data_fim_reserva)\n",
    "print(\"Período em dias:\", periodo)"
